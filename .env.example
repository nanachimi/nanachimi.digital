# Database
DATABASE_URL="postgresql://user:password@localhost:5432/nanachimi?schema=public"

# Anthropic API (for AI plan generation in admin)
ANTHROPIC_API_KEY="sk-ant-..."
# Model override (default: claude-3-haiku-20240307, production: claude-sonnet-4-20250514)
# ANTHROPIC_MODEL="claude-sonnet-4-20250514"

# Site
NEXT_PUBLIC_SITE_URL="https://nanachimi.digital"

# Email
# Development: Use MailHog (docker run -d -p 1025:1025 -p 8025:8025 mailhog/mailhog)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
EMAIL_FROM="nanachimi.digital <info@nanachimi.digital>"

# SeaweedFS (file storage for PDFs)
# Development: docker run -d --name seaweedfs -p 9333:9333 -p 8080:8080 -p 8888:8888 chrislusf/seaweedfs server -master -volume -filer
SEAWEEDFS_MASTER_URL=http://localhost:9333
SEAWEEDFS_FILER_URL=http://localhost:8888

# Admin Authentication
# Generate session secret: openssl rand -hex 32
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your-secure-password-here
ADMIN_TOTP_SECRET=
SESSION_SECRET="your-32-char-minimum-secret-here"

# Stripe (Online-Zahlung)
# Erstellen Sie einen Account auf https://dashboard.stripe.com
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_PUBLISHABLE_KEY="pk_test_..."
# Webhook Secret: stripe listen --forward-to localhost:3000/api/stripe/webhook
STRIPE_WEBHOOK_SECRET="whsec_..."

# Health Check (CI/CD pipeline access to /api/health without admin session)
# Generate: openssl rand -hex 32
HEALTH_CHECK_SECRET="your-health-check-secret-here"

# Cal.com (Terminbuchung)
# Erstellen Sie einen Account auf https://cal.com und tragen Sie Ihren Username ein
# NEXT_PUBLIC_CALCOM_USERNAME=your-calcom-username
