# Database
DATABASE_URL="postgresql://user:password@localhost:5432/nanachimi?schema=public"

# Anthropic API (for AI plan generation in admin)
ANTHROPIC_API_KEY="sk-ant-..."
# Model override (default: claude-3-haiku-20240307, production: claude-sonnet-4-20250514)
# ANTHROPIC_MODEL="claude-sonnet-4-20250514"

# Site
NEXT_PUBLIC_SITE_URL="https://nanachimi.digital"

# Email
# Development: Use MailHog (docker run -d -p 1025:1025 -p 8025:8025 mailhog/mailhog)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
EMAIL_FROM="nanachimi.digital <info@nanachimi.digital>"

# SeaweedFS (file storage for PDFs)
# Development: docker run -d --name seaweedfs -p 9333:9333 -p 8080:8080 -p 8888:8888 chrislusf/seaweedfs server -master -volume -filer
SEAWEEDFS_MASTER_URL=http://localhost:9333
SEAWEEDFS_FILER_URL=http://localhost:8888

# Admin Authentication
# Generate session secret: openssl rand -hex 32
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your-secure-password-here
ADMIN_TOTP_SECRET=
SESSION_SECRET="your-32-char-minimum-secret-here"

# Affiliate Authentication
# Generate: openssl rand -hex 32
AFFILIATE_SESSION_SECRET="your-affiliate-session-secret-here"

# Stripe (Online-Zahlung)
# Erstellen Sie einen Account auf https://dashboard.stripe.com
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_PUBLISHABLE_KEY="pk_test_..."
# Webhook Secret: stripe listen --forward-to localhost:3000/api/stripe/webhook
STRIPE_WEBHOOK_SECRET="whsec_..."

# Health Check (CI/CD pipeline access to /api/health without admin session)
# Generate: openssl rand -hex 32
HEALTH_CHECK_SECRET="your-health-check-secret-here"

# Cron Job Secret (required for /api/cron/* endpoints)
# Generate: openssl rand -hex 32
CRON_SECRET="your-cron-secret-here"

# Terminbuchung: custom implementation (no third-party dependency)

# WhatsApp Business API (Meta Cloud API)
# WHATSAPP_PHONE_NUMBER_ID=
# WHATSAPP_ACCESS_TOKEN=
WHATSAPP_MOCK=true

# Interne WhatsApp-Benachrichtigungen
WHATSAPP_ADMIN_PHONE=+4917612345678
WHATSAPP_INTERNAL_ENABLED=true

# Twilio (SMS verification)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Sentry (error tracking — free at sentry.io)
# NEXT_PUBLIC_SENTRY_DSN=https://xxx@o123.ingest.sentry.io/456
# SENTRY_AUTH_TOKEN=sntrys_...
# SENTRY_ORG=your-org
# SENTRY_PROJECT=nanachimi-digital

# Off-site backups (S3-compatible: Hetzner Object Storage, Backblaze B2, AWS S3)
# BACKUP_S3_ENDPOINT=https://fsn1.your-objectstorage.com
# BACKUP_S3_BUCKET=nanachimi-backups
# BACKUP_S3_ACCESS_KEY=
# BACKUP_S3_SECRET_KEY=
