generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ---------------------------------------------------------------------------
// Submissions (Anfragen)
// ---------------------------------------------------------------------------

model Submission {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  status    String   @default("pending")

  // Contact
  name    String
  email   String
  firma   String?
  telefon String?

  // Project
  projekttyp         String
  beschreibung       String
  zielgruppe         String
  funktionen         String[]
  rollenAnzahl       String
  rollenBeschreibung String?
  appStruktur        String?
  rollenApps         Json?
  designLevel        String
  zeitrahmenMvp      String
  zeitrahmenFinal    String
  budget             String
  betriebUndWartung  String
  betriebLaufzeit    String?
  zusatzinfo         String?

  // Branding & Artifacts
  markenname   String?
  domain       String?
  brandingInfo String?

  // Flow
  naechsterSchritt String
  clientFeedback   String?
  bookingId        String?

  // Estimate (auto-generated, internal)
  estimate     Json
  range        Json?
  riskLevel    String?
  slaMinutes   Int?
  slaDeadline  DateTime?
  slaStartedAt DateTime?
  demandFactor Float?

  // Admin amendment
  amendment Json?

  // Relations
  angebote Angebot[]
  bookings Booking[]
  ratings  OnboardingRating[]
  files    SubmissionFile[]

  @@index([status])
  @@index([createdAt])
  @@index([slaDeadline])
}

// ---------------------------------------------------------------------------
// Angebote (Offers)
// ---------------------------------------------------------------------------

model Angebot {
  id           String   @id @default(cuid())
  submissionId String
  submission   Submission @relation(fields: [submissionId], references: [id])
  version      Int
  status       String   @default("draft")
  createdAt    DateTime @default(now())
  sentAt       DateTime?

  festpreis Int
  aufwand   Int // Personentage

  plan       Json
  pdfFileId  String?
  adminNotes String?

  clientFeedback String?

  isAutoGenerated  Boolean   @default(false)
  autoGeneratedAt  DateTime?
  demandFactor     Float?

  payments Payment[]

  @@index([submissionId])
}

// ---------------------------------------------------------------------------
// Payments (Zahlungen)
// ---------------------------------------------------------------------------

model Payment {
  id          String    @id @default(cuid())
  angebotId   String
  angebot     Angebot   @relation(fields: [angebotId], references: [id])
  amount      Int       // Betrag in Cent
  discount    Int       @default(0) // Rabatt in Cent
  type        String    // "tranche_1" | "half" | "full"
  method      String    // "stripe" | "bank_transfer"
  stripeId    String?   // Stripe Checkout Session ID
  status      String    @default("pending") // pending | paid | failed
  paidAt      DateTime?
  createdAt   DateTime  @default(now())

  @@index([angebotId])
  @@index([stripeId])
}

// ---------------------------------------------------------------------------
// Bookings (Termine)
// ---------------------------------------------------------------------------

model Booking {
  id           String      @id @default(cuid())
  submissionId String?
  submission   Submission? @relation(fields: [submissionId], references: [id])
  createdAt    DateTime    @default(now())
  date         String      // "YYYY-MM-DD"
  startTime    String      // "HH:MM"
  endTime      String      // "HH:MM"
  status       String      @default("confirmed")

  // Denormalized contact info
  name    String
  email   String
  firma   String?
  telefon String?

  @@index([date, status])
}

// ---------------------------------------------------------------------------
// Availability (recurring weekly slots)
// ---------------------------------------------------------------------------

model AvailabilitySlot {
  id          String @id @default(cuid())
  dayOfWeek   Int    // 0=Sunday ... 6=Saturday
  startHour   Int
  startMinute Int
  endHour     Int
  endMinute   Int
}

model BookingSettings {
  id                    String @id @default("default")
  meetingDurationMinutes Int    @default(30) // 15, 30, 45, 60
  bufferMinutes         Int    @default(0)  // Break between meetings
}

// ---------------------------------------------------------------------------
// A/B Tests
// ---------------------------------------------------------------------------

model ABTest {
  id            String    @id @default(cuid())
  name          String
  targetElement String
  status        String    @default("draft")
  variants      Json      // ABTestVariant[]
  createdAt     DateTime  @default(now())
  startedAt     DateTime?
  pausedAt      DateTime?
  completedAt   DateTime?

  events ABEvent[]
}

model ABEvent {
  id             String   @id @default(cuid())
  testId         String
  test           ABTest   @relation(fields: [testId], references: [id], onDelete: Cascade)
  variantId      String
  visitorId      String
  type           String   // "impression" | "conversion"
  conversionType String?
  page           String?
  createdAt      DateTime @default(now())

  @@index([testId])
  @@index([visitorId])
}

// ---------------------------------------------------------------------------
// Analytics — Page Views
// ---------------------------------------------------------------------------

model PageView {
  id          String   @id @default(cuid())
  visitorId   String
  ip          String?  // Client IP for retroactive exclusion
  path        String
  referrer    String   @default("")
  utmSource   String?
  utmMedium   String?
  utmCampaign String?
  timeOnPage  Float?
  scrollDepth Int?
  timestamp   DateTime @default(now())

  @@index([visitorId])
  @@index([timestamp])
  @@index([ip])
}

// ---------------------------------------------------------------------------
// Analytics — Onboarding Events
// ---------------------------------------------------------------------------

model OnboardingAnalyticsEvent {
  id        String   @id @default(cuid())
  visitorId String
  ip        String?  // Client IP for retroactive exclusion
  sessionId String
  step      Int
  stepName  String
  type      String   // "step_enter" | "step_complete" | "abandon" | "funnel_complete"
  duration  Float?
  timestamp DateTime @default(now())

  @@index([sessionId])
  @@index([ip])
}

// ---------------------------------------------------------------------------
// Analytics — Conversion Events
// ---------------------------------------------------------------------------

model ConversionEvent {
  id             String   @id @default(cuid())
  visitorId      String
  ip             String?  // Client IP for retroactive exclusion
  type           String   // "cta_click" | "conversion_path"
  ctaId          String?
  conversionPath String?
  page           String
  timestamp      DateTime @default(now())

  @@index([ip])
}

// ---------------------------------------------------------------------------
// Pricing Config (singleton)
// ---------------------------------------------------------------------------

model PricingConfig {
  id        String   @id @default("default")
  config    Json
  updatedAt DateTime @updatedAt
}

// ---------------------------------------------------------------------------
// Contact Messages
// ---------------------------------------------------------------------------

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  company   String?
  message   String
  createdAt DateTime @default(now())
}

// ---------------------------------------------------------------------------
// Onboarding Rating (feedback after completion)
// ---------------------------------------------------------------------------

model OnboardingRating {
  id           String      @id @default(cuid())
  submissionId String?
  submission   Submission? @relation(fields: [submissionId], references: [id])
  rating       Int
  comment      String?
  createdAt    DateTime    @default(now())
}

// ---------------------------------------------------------------------------
// Submission Files (uploaded during onboarding)
// ---------------------------------------------------------------------------

model SubmissionFile {
  id           String      @id @default(cuid())
  submissionId String?
  submission   Submission? @relation(fields: [submissionId], references: [id])
  tempToken    String?     @unique // links files before submission exists
  filename     String
  fileSize     Int
  contentType  String
  seaweedFid   String      // SeaweedFS file ID
  category     String      // "branding" | "mockup" | "reference" | "other"
  createdAt    DateTime    @default(now())

  @@index([submissionId])
  @@index([tempToken])
}

// ---------------------------------------------------------------------------
// Excluded IPs (for analytics filtering)
// ---------------------------------------------------------------------------

model ExcludedIp {
  id        String   @id @default(cuid())
  ip        String   @unique
  label     String?  // e.g. "Founder", "Tester Max"
  createdAt DateTime @default(now())
}

// ---------------------------------------------------------------------------
// Job Queue (persistente Aufgaben mit Retry)
// ---------------------------------------------------------------------------

model Job {
  id          String    @id @default(cuid())
  type        String    // "angebot_accepted_email"
  payload     Json      // Aufgaben-spezifische Daten
  status      String    @default("pending") // pending | processing | completed | failed
  attempts    Int       @default(0)
  maxAttempts Int       @default(5)
  lastError   String?
  nextRunAt   DateTime  @default(now())
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([status, nextRunAt])
  @@index([type])
}

// ---------------------------------------------------------------------------
// Incidents (Vorfälle / Alarme im Admin-Backoffice)
// ---------------------------------------------------------------------------

model Incident {
  id          String    @id @default(cuid())
  severity    String    // "critical" | "warning" | "info"
  title       String
  message     String
  source      String    // "job_queue" | "payment" | "email" | "system"
  referenceId String?   // e.g. jobId, angebotId
  status      String    @default("open") // open | acknowledged | resolved
  resolvedAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([status])
  @@index([severity])
  @@index([createdAt])
}
