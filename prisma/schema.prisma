generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ---------------------------------------------------------------------------
// Submissions (Anfragen)
// ---------------------------------------------------------------------------

model Submission {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  status    String   @default("pending")

  // Contact
  name    String
  email   String
  firma   String?
  telefon String?

  // Project
  projekttyp         String
  beschreibung       String
  zielgruppe         String?
  funktionen         String[]
  rollenAnzahl       String
  rollenName         String?
  rollenBeschreibung String?
  appStruktur        String?
  rollenApps         Json?
  designLevel        String
  zeitrahmenMvp      String
  zeitrahmenFinal    String
  budget             String
  betriebUndWartung  String
  betriebLaufzeit    String?
  zusatzinfo         String?

  // Branding & Artifacts
  markenname   String?
  domain       String?
  brandingInfo String?

  // Funktionen-Gruppen-Zuordnung
  funktionenGruppen Json? // Record<string, string[]>

  // Inspiration & Monetarisierung
  inspirationUrls        Json? // Array<{ url: string, beschreibung: string }>
  monetarisierung        String[] // Multi-Select Werte
  monetarisierungDetails String?
  werZahlt               String?
  zahlendeGruppen        String[] // Rollennamen die zahlen

  // WhatsApp consent (DSGVO)
  whatsappConsent        Boolean   @default(false)
  whatsappConsentAt      DateTime?
  whatsappConsentVersion String?

  // Flow
  naechsterSchritt String
  clientFeedback   String?
  bookingId        String?

  // Estimate (auto-generated, internal)
  estimate      Json
  range         Json?
  riskLevel     String?
  slaMinutes    Int?
  slaDeadline   DateTime?
  slaStartedAt  DateTime?
  slaBreachedAt DateTime?
  demandFactor  Float?

  // Admin amendment
  amendment Json?

  // Affiliate & promo attribution
  promoCode             String? // code saisi par le client (lisible ex: "SysysStartup50")
  promoCodeId           String?
  promoCodeRef          PromoCode? @relation(fields: [promoCodeId], references: [id])
  affiliateId           String? // attribution finale — promo wins > first-touch
  affiliate             Affiliate? @relation("SubmissionWinner", fields: [affiliateId], references: [id])
  firstTouchAffiliateId String? // source cookie (analytics only)
  firstTouchAffiliate   Affiliate? @relation("SubmissionFirstTouch", fields: [firstTouchAffiliateId], references: [id])
  visitorId             String? // lien vers tracking analytics (PageView.visitorId)
  utmSource             String?
  utmMedium             String?
  utmCampaign           String?

  // Relations
  angebote  Angebot[]
  bookings  Booking[]
  ratings   OnboardingRating[]
  files     SubmissionFile[]
  referrals Referral[]

  @@index([status])
  @@index([createdAt])
  @@index([slaDeadline])
  @@index([affiliateId])
  @@index([promoCodeId])
}

// ---------------------------------------------------------------------------
// Angebote (Offers)
// ---------------------------------------------------------------------------

model Angebot {
  id            String     @id @default(cuid())
  angebotNummer String?    @unique // e.g. "AN-2026-0001" — sequential, human-readable
  submissionId  String
  submission    Submission @relation(fields: [submissionId], references: [id])
  version       Int
  status        String     @default("draft")
  createdAt     DateTime   @default(now())
  sentAt        DateTime?

  festpreis Int
  aufwand   Int // Personentage

  plan       Json
  pdfFileId  String?
  adminNotes String?

  clientFeedback String?

  isAutoGenerated Boolean   @default(false)
  autoGeneratedAt DateTime?
  demandFactor    Float?
  betreuungMonate Int?

  payments Payment[]

  @@index([submissionId])
}

// ---------------------------------------------------------------------------
// Payments (Zahlungen)
// ---------------------------------------------------------------------------

model Payment {
  id             String    @id @default(cuid())
  angebotId      String
  angebot        Angebot   @relation(fields: [angebotId], references: [id])
  amount         Int // Betrag in Cent — montant net effectivement encaissé (après toutes réductions)
  discount       Int       @default(0) // Rabatt in Cent (payment-time discount: full/half)
  promoDiscount  Int       @default(0) // Rabatt in Cent from promo code (separate from payment-time discount)
  type           String // "tranche_1" | "half" | "full"
  method         String // "stripe" | "bank_transfer"
  stripeId       String? // Stripe Checkout Session ID
  status         String    @default("pending") // pending | paid | failed
  paidAt         DateTime?
  rechnungNummer String?
  rechnungFileId String?
  createdAt      DateTime  @default(now())

  // Commission liée (1 payment = 0 ou 1 commission)
  commission Commission?

  @@index([angebotId])
  @@index([stripeId])
}

// ---------------------------------------------------------------------------
// Bookings (Termine)
// ---------------------------------------------------------------------------

model Booking {
  id           String      @id @default(cuid())
  submissionId String?
  submission   Submission? @relation(fields: [submissionId], references: [id])
  createdAt    DateTime    @default(now())
  date         String // "YYYY-MM-DD"
  startTime    String // "HH:MM"
  endTime      String // "HH:MM"
  status       String      @default("confirmed")

  // Denormalized contact info
  name    String
  email   String
  firma   String?
  telefon String?

  @@index([date, status])
}

// ---------------------------------------------------------------------------
// Availability (recurring weekly slots)
// ---------------------------------------------------------------------------

model AvailabilitySlot {
  id          String @id @default(cuid())
  dayOfWeek   Int // 0=Sunday ... 6=Saturday
  startHour   Int
  startMinute Int
  endHour     Int
  endMinute   Int
}

model BookingSettings {
  id                     String @id @default("default")
  meetingDurationMinutes Int    @default(30) // 15, 30, 45, 60
  bufferMinutes          Int    @default(0) // Break between meetings
}

// ---------------------------------------------------------------------------
// A/B Tests
// ---------------------------------------------------------------------------

model ABTest {
  id            String    @id @default(cuid())
  name          String
  targetElement String
  status        String    @default("draft")
  variants      Json // ABTestVariant[]
  createdAt     DateTime  @default(now())
  startedAt     DateTime?
  pausedAt      DateTime?
  completedAt   DateTime?

  events ABEvent[]
}

model ABEvent {
  id             String   @id @default(cuid())
  testId         String
  test           ABTest   @relation(fields: [testId], references: [id], onDelete: Cascade)
  variantId      String
  visitorId      String
  type           String // "impression" | "conversion"
  conversionType String?
  page           String?
  createdAt      DateTime @default(now())

  @@index([testId])
  @@index([visitorId])
}

// ---------------------------------------------------------------------------
// Analytics — Page Views
// ---------------------------------------------------------------------------

model PageView {
  id          String   @id @default(cuid())
  visitorId   String
  ip          String? // Client IP for retroactive exclusion
  country     String? // ISO 3166-1 alpha-2 (e.g., "DE", "AT", "CH")
  city        String?
  path        String
  referrer    String   @default("")
  utmSource   String?
  utmMedium   String?
  utmCampaign String?
  timeOnPage  Float?
  scrollDepth Int?
  timestamp   DateTime @default(now())

  @@index([visitorId])
  @@index([timestamp])
  @@index([ip])
  @@index([country])
}

// ---------------------------------------------------------------------------
// Analytics — Onboarding Events
// ---------------------------------------------------------------------------

model OnboardingAnalyticsEvent {
  id        String   @id @default(cuid())
  visitorId String
  ip        String? // Client IP for retroactive exclusion
  sessionId String
  step      Int
  stepName  String
  type      String // "step_enter" | "step_complete" | "abandon" | "funnel_complete"
  duration  Float?
  timestamp DateTime @default(now())

  @@index([sessionId])
  @@index([ip])
}

// ---------------------------------------------------------------------------
// Analytics — Conversion Events
// ---------------------------------------------------------------------------

model ConversionEvent {
  id             String   @id @default(cuid())
  visitorId      String
  ip             String? // Client IP for retroactive exclusion
  type           String // "cta_click" | "conversion_path"
  ctaId          String?
  conversionPath String?
  page           String
  timestamp      DateTime @default(now())

  @@index([ip])
}

// ---------------------------------------------------------------------------
// Pricing Config (singleton)
// ---------------------------------------------------------------------------

model PricingConfig {
  id        String   @id @default("default")
  config    Json
  updatedAt DateTime @updatedAt
}

// ---------------------------------------------------------------------------
// Admin Settings (key-value store for TOTP secret, etc.)
// ---------------------------------------------------------------------------

model AdminSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

// ---------------------------------------------------------------------------
// Contact Messages
// ---------------------------------------------------------------------------

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  company   String?
  message   String
  createdAt DateTime @default(now())
}

// ---------------------------------------------------------------------------
// Onboarding Rating (feedback after completion)
// ---------------------------------------------------------------------------

model OnboardingRating {
  id           String      @id @default(cuid())
  submissionId String?
  submission   Submission? @relation(fields: [submissionId], references: [id])
  rating       Int
  comment      String?
  createdAt    DateTime    @default(now())
}

// ---------------------------------------------------------------------------
// Submission Files (uploaded during onboarding)
// ---------------------------------------------------------------------------

model SubmissionFile {
  id           String      @id @default(cuid())
  submissionId String?
  submission   Submission? @relation(fields: [submissionId], references: [id])
  tempToken    String?     @unique // links files before submission exists
  filename     String
  fileSize     Int
  contentType  String
  seaweedFid   String // SeaweedFS file ID
  category     String // "branding" | "mockup" | "reference" | "other"
  createdAt    DateTime    @default(now())

  @@index([submissionId])
  @@index([tempToken])
}

// ---------------------------------------------------------------------------
// Excluded IPs (for analytics filtering)
// ---------------------------------------------------------------------------

model ExcludedIp {
  id        String   @id @default(cuid())
  ip        String   @unique
  label     String? // e.g. "Founder", "Tester Max"
  createdAt DateTime @default(now())
}

// ---------------------------------------------------------------------------
// Job Queue (persistente Aufgaben mit Retry)
// ---------------------------------------------------------------------------

model Job {
  id             String    @id @default(cuid())
  type           String // "angebot_accepted_email" | "whatsapp_customer_confirmation" | "whatsapp_internal_notification"
  payload        Json // Aufgaben-spezifische Daten
  status         String    @default("pending") // pending | processing | completed | failed
  attempts       Int       @default(0)
  maxAttempts    Int       @default(5)
  lastError      String?
  idempotencyKey String?   @unique
  nextRunAt      DateTime  @default(now())
  completedAt    DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([status, nextRunAt])
  @@index([type])
}

// ---------------------------------------------------------------------------
// Incidents (Vorfälle / Alarme im Admin-Backoffice)
// ---------------------------------------------------------------------------

model Incident {
  id          String    @id @default(cuid())
  severity    String // "critical" | "warning" | "info"
  title       String
  message     String
  source      String // "job_queue" | "payment" | "email" | "system"
  referenceId String? // e.g. jobId, angebotId
  status      String    @default("open") // open | acknowledged | resolved
  resolvedAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([status])
  @@index([severity])
  @@index([createdAt])
}

// ---------------------------------------------------------------------------
// Company Settings (singleton — configurable in backoffice)
// ---------------------------------------------------------------------------

model CompanySettings {
  id           String   @id @default("default")
  companyName  String   @default("nanachimi.digital")
  ownerName    String   @default("Achille Nana Chimi")
  street       String   @default("")
  plz          String   @default("67227")
  city         String   @default("Frankenthal")
  country      String   @default("Deutschland")
  email        String   @default("info@nanachimi.digital")
  phone        String? // optional
  website      String   @default("nanachimi.digital")
  steuernummer String   @default("")
  ustIdNr      String? // USt-IdNr (optional, recommended for B2B)
  vatRate      Float    @default(19) // MwSt-Satz in %
  iban         String   @default("DE89 3704 0044 0532 0130 00")
  bic          String   @default("COBADEFFXXX")
  bankName     String   @default("Commerzbank")
  kontoinhaber String   @default("Achille Nana Chimi")
  updatedAt    DateTime @updatedAt
}

// ---------------------------------------------------------------------------
// Phone Verification (SMS codes)
// ---------------------------------------------------------------------------

model PhoneVerification {
  id        String   @id @default(cuid())
  phone     String // E.164 format
  code      String // 6-digit code
  expiresAt DateTime
  verified  Boolean  @default(false)
  attempts  Int      @default(0)
  createdAt DateTime @default(now())

  @@index([phone, code])
  @@index([expiresAt])
}

// ---------------------------------------------------------------------------
// Affiliates (Partner-Programm)
// ---------------------------------------------------------------------------

model Affiliate {
  id                       String    @id @default(cuid())
  email                    String    @unique
  passwordHash             String
  name                     String
  handle                   String    @unique // ex: "syssys35" (sans @), utilisé pour /@handle
  commissionRate           Decimal   @db.Decimal(5, 4) // ex: 0.1000 = 10%, 0.1500 = 15%
  status                   String    @default("pending") // "pending" | "active" | "suspended"
  stripeConnectedAccountId String? // rempli en Phase 3
  stripeOnboardingComplete Boolean   @default(false)
  approvedAt               DateTime?
  approvedBy               String?
  createdAt                DateTime  @default(now())
  updatedAt                DateTime  @updatedAt

  // Relations
  promoCodes            PromoCode[]
  referrals             Referral[]
  commissions           Commission[]
  payouts               Payout[]
  applications          AffiliateApplication[]
  submissionsWon        Submission[]           @relation("SubmissionWinner")
  submissionsFirstTouch Submission[]           @relation("SubmissionFirstTouch")

  @@index([status])
  @@index([handle])
}

model AffiliateApplication {
  id          String     @id @default(cuid())
  email       String
  name        String
  handle      String // souhaité; validé à l'approbation
  audience    String // qui sont leurs followers, quelle audience
  motivation  String // pourquoi rejoindre le programme
  status      String     @default("pending") // "pending" | "approved" | "rejected"
  reviewedAt  DateTime?
  reviewedBy  String?
  notes       String?
  affiliateId String? // rempli après approbation
  affiliate   Affiliate? @relation(fields: [affiliateId], references: [id])
  createdAt   DateTime   @default(now())

  @@index([status, createdAt])
}

// ---------------------------------------------------------------------------
// Campaigns & PromoCodes
// ---------------------------------------------------------------------------

model Campaign {
  id              String    @id @default(cuid())
  name            String // "Lancement Q2 2026", "Black Friday 2026"
  campaignCode    String    @unique // ex: "Startup2026" — also serves as admin promo code (lowercased)
  discountPercent Decimal   @db.Decimal(5, 4) // 0.5000 = 50%
  description     String? // visible aux affiliés dans leur dashboard
  validFrom       DateTime  @default(now())
  validUntil      DateTime?
  maxUsesPerCode  Int? // limite d'utilisations par code individuel (null = illimité)
  active          Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  promoCodes PromoCode[]

  @@index([active, validUntil])
}

model PromoCode {
  id              String     @id @default(cuid())
  code            String // lowercase: admin = campaignCode, affiliate = handle+percentInt (e.g. "sysys3525")
  campaignId      String
  campaign        Campaign   @relation(fields: [campaignId], references: [id])
  affiliateId     String? // null = code admin (généré automatiquement à la création de la Campaign)
  affiliate       Affiliate? @relation(fields: [affiliateId], references: [id])
  discountPercent Decimal    @db.Decimal(5, 4) // snapshot du % de la campagne à la création
  maxUses         Int? // hérité de Campaign.maxUsesPerCode à la création
  usedCount       Int        @default(0)
  active          Boolean    @default(true)
  createdAt       DateTime   @default(now())

  submissions Submission[]

  @@unique([campaignId, affiliateId]) // 1 affilié = 1 code par campagne max
  @@index([code, active])
  @@index([affiliateId])
}

// ---------------------------------------------------------------------------
// Referrals, Commissions & Payouts
// ---------------------------------------------------------------------------

model Referral {
  id              String      @id @default(cuid())
  visitorId       String // lié au tracking analytics existant (PageView.visitorId)
  affiliateId     String
  affiliate       Affiliate   @relation(fields: [affiliateId], references: [id])
  source          String // "handle_link" | "promo_code"
  firstTouchAt    DateTime    @default(now())
  cookieExpiresAt DateTime // firstTouchAt + 2 ans
  submissionId    String? // rempli à la conversion
  submission      Submission? @relation(fields: [submissionId], references: [id])
  convertedAt     DateTime?
  createdAt       DateTime    @default(now())

  @@index([visitorId, affiliateId])
  @@index([affiliateId, convertedAt])
}

model Commission {
  id                  String    @id @default(cuid())
  affiliateId         String
  affiliate           Affiliate @relation(fields: [affiliateId], references: [id])
  paymentId           String    @unique // 1 payment → 1 commission max
  payment             Payment   @relation(fields: [paymentId], references: [id])
  amount              Int // cents — commission calculée sur payment.amount réel
  rateSnapshot        Decimal   @db.Decimal(5, 4) // taux à la date de création
  status              String    @default("pending") // "pending" | "approved" | "paid" | "void"
  earnedAt            DateTime  @default(now())
  approvedAt          DateTime? // après fenêtre de rétractation (14j)
  commissionExpiresAt DateTime // earnedAt + 2 ans — fenêtre d'éligibilité
  payoutId            String?
  payout              Payout?   @relation(fields: [payoutId], references: [id])

  @@index([affiliateId, status])
  @@index([commissionExpiresAt])
  @@index([status, approvedAt])
}

model Payout {
  id               String    @id @default(cuid())
  affiliateId      String
  affiliate        Affiliate @relation(fields: [affiliateId], references: [id])
  amountTotal      Int // cents
  currency         String    @default("eur")
  status           String    @default("pending") // "pending" | "processing" | "paid" | "failed"
  stripeTransferId String?
  periodStart      DateTime
  periodEnd        DateTime
  createdAt        DateTime  @default(now())
  paidAt           DateTime?
  failureReason    String?

  commissions Commission[]

  @@index([affiliateId, status])
}
